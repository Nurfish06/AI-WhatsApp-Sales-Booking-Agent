POSTGRES_USER=n8n_user
POSTGRES_PASSWORD=n8n_secure_password
POSTGRES_DB=whatsapp_agent_db

N8N_ENCRYPTION_KEY=generate_a_random_key_here
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
NODE_ENV=production
WEBHOOK_URL=http://localhost:5678/

# Twilio & OpenAI will be stored securely inside n8n's encrypted vault
# but can be defined here if you need them in custom scripts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
OPENAI_API_KEY=
